{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dtn-publisher-scheduler",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dtnpblisher",
      "database_id": "8e6e2174-36a5-4c33-818d-9f047883a36c"
    }
  ]
}
