{
  "entities": {
    "BotConfig": {
      "title": "Bot Configuration",
      "description": "Configuration for the Telegram bot",
      "type": "object",
      "properties": {
        "botToken": {
          "type": "string",
          "description": "Telegram Bot API Token",
          "minLength": 1
        },
        "channelId": {
          "type": "string",
          "description": "Telegram Channel ID or handle",
          "minLength": 1
        }
      },
      "required": ["botToken", "channelId"]
    }
  },
  "firestore": {
    "/botConfig/{userId}": {
      "schema": "BotConfig",
      "description": "Telegram bot configuration per user"
    }
  }
}
